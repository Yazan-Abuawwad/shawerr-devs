# ═══════════════════════════════════════════════════
# GOLD MONITOR — Environment Variables
# ═══════════════════════════════════════════════════

# ── Spring Boot Backend ──────────────────────────
# HTTP port (default: 3001)
PORT=3001

# PostgreSQL JDBC connection URL
DATABASE_URL=jdbc:postgresql://localhost:5432/gold_monitor

# PostgreSQL credentials
DB_USERNAME=postgres
DB_PASSWORD=your_password

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# ── LLM Configuration ────────────────────────────
# Ollama endpoint (local or VPS)
# Local:  http://localhost:11434
# VPS:    http://YOUR_VPS_IP:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Angular Frontend ─────────────────────────────
# No build-time environment variable needed;
# the Angular dev server proxies /api/* → localhost:3001 via proxy.conf.json
